# ─────────────────────────────────────────────────────────────────────────────
# Jelly-Claude .env — copy to .env and fill in your keys
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Choose ONE: Anthropic (paid Claude models) OR OpenRouter (free/cheap) ────

# Option A: Anthropic API key — get one at https://console.anthropic.com
# Uses Claude's default paid model tiers automatically.
ANTHROPIC_API_KEY=

# Option B: OpenRouter API key — get one at https://openrouter.ai/keys
# jelly-claude.sh will configure the free/low-cost model tiers below.
OPENROUTER_API_KEY=

# ── OpenRouter model tiers (auto-set by jelly-claude.sh — override if needed) ─
# These are only used when OPENROUTER_API_KEY is set and ANTHROPIC_API_KEY is not.
# ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek/deepseek-r1:free
# ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek/deepseek-chat:free
# ANTHROPIC_DEFAULT_HAIKU_MODEL=meta-llama/llama-3.3-70b-instruct:free
# CLAUDE_CODE_SUBAGENT_MODEL=google/gemma-2-9b-it:free
